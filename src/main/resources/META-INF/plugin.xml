<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>gdnwxf.copywithlinenumbers</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>Copy Extra By QingHao</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor email="gdnwxf@gmail.com" url="https://github.com/gdnwxf/CopyWithLineNumbers">gdnwxf</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Simple HTML elements (text formatting, paragraphs, and lists) can be added inside of <![CDATA[ ]]> tag.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
    <description><![CDATA[
    Copy selected lines with line number (and file path).
    <ul>
    <li>Copy With Line Numbers: With Full Path</li>
    <li>Copy With Line Numbers: With Relative Path</li>
    <li>Copy Full File Path and Line Range</li>
    <li>Copy Full File Path and Line Range Only</li>
    <li>Copy Relative File Path and Line Range</li>
    <li>Copy Relative File Path and Line Range Only</li>
    </ul>
    <p>Updated icon.</p>
]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>

    <idea-version since-build="253"/>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij"/>

    <actions>
        <group id="gdnwxf.CopyExtraGroup"
               text="Copy Extra"
               description="Extra copy actions"
               popup="true">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            <action id="gdnwxf.CopyWithRelativeFilePathAndLineRangeOnlyAction"
                    class="gdnwxf.CopyWithRelativeFilePathAndLineRangeOnlyAction"
                    text="Copy Relative Path Line Range Only"
                    description="Copy only relative file path and selected line range"/>
            <action id="gdnwxf.CopyWithFullFilePathAndLineRangeOnlyAction"
                    class="gdnwxf.CopyWithFullFilePathAndLineRangeOnlyAction"
                    text="Copy Full Path and Line Range Only"
                    description="Copy only full file path and selected line range"/>
            <separator/>
            <action id="gdnwxf.CopyWithRelativeFilePathAndLineRangeSelectedAction"
                    class="gdnwxf.CopyWithRelativeFilePathAndLineRangeSelectedAction"
                    text="Copy Relative Path Line Range Selected"
                    description="Copy relative file path and line range with selected code only"/>
            <action id="gdnwxf.CopyWithLineNumbersWithRelativeFilePathSelectedAction"
                    class="gdnwxf.CopyWithLineNumbersWithRelativeFilePathSelectedAction"
                    text="Copy Relative Path Line Numbers Selected"
                    description="Copy relative file path and line range with selected code and line numbers"/>
            <action id="gdnwxf.CopyWithFullFilePathAndLineRangeSelectedAction"
                    class="gdnwxf.CopyWithFullFilePathAndLineRangeSelectedAction"
                    text="Copy Full Path Line Range Selected"
                    description="Copy full file path and line range with selected code only"/>
            <action id="gdnwxf.CopyWithLineNumbersWithFullFilePathAndLineRangeSelectedAction"
                    class="gdnwxf.CopyWithLineNumbersWithFullFilePathAndLineRangeSelectedAction"
                    text="Copy Full Path Line Numbers Selected"
                    description="Copy full file path and line range with selected code and line numbers"/>
            <separator/>
            <action id="gdnwxf.CopyWithRelativeFilePathAndLineRangeAction"
                    class="gdnwxf.CopyWithRelativeFilePathAndLineRangeAction"
                    text="Copy Relative Path Line Range"
                    description="Copy relative file path and selected line range with original content"/>
            <action id="gdnwxf.CopyWithLineNumbersWithRelativeFilePathAction"
                    class="gdnwxf.CopyWithLineNumbersWithRelativeFilePathAction"
                    text="Copy Relative Path Line Numbers"
                    description="Copy relative file path with line numbers"/>
            <action id="gdnwxf.CopyWithLineNumbersWithFileNameAndLineRangeAction"
                    class="gdnwxf.CopyWithLineNumbersWithFileNameAndLineRangeAction"
                    text="Copy Full Path Line Range"
                    description="Copy full file path and selected line range with original content"/>
            <action id="gdnwxf.CopyWithLineNumbersWithFullFilePathAction"
                    class="gdnwxf.CopyWithLineNumbersWithFullFilePathAction"
                    text="Copy Full Path Line Numbers"
                    description="Copy full file path with line numbers"/>
        </group>
        <group id="gdnwxf.ProjectViewCopyExtraGroup"
               text="Copy Extra"
               description="Extra copy actions for project view"
               popup="true">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="first"/>
            <action id="gdnwxf.ProjectViewCopyWithRelativePathAction"
                    class="gdnwxf.ProjectViewCopyWithRelativePathAction"
                    text="Copy With Relative Path"
                    description="Copy relative path(s) of selected file(s), one per line"/>
            <action id="gdnwxf.ProjectViewCopyWithFullPathAction"
                    class="gdnwxf.ProjectViewCopyWithFullPathAction"
                    text="Copy With Full Path"
                    description="Copy full path(s) of selected file(s), one per line"/>
        </group>
    </actions>
</idea-plugin>
